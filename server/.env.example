# ---------------------------------------------------------------------------
# Z-Portal server – copy to .env (dev) or .env.production (production). Never commit.
# Local (no Docker): use your macOS username, e.g. postgresql://YOUR_USERNAME@localhost:5432/zportal
# Docker/production: use hostname `db` and password, e.g. postgresql://zportal:PASSWORD@db:5432/zportal
# ---------------------------------------------------------------------------

# Local dev (PostgreSQL installed via Homebrew; replace YOUR_USERNAME with output of 'whoami'):
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/zportal
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
NODE_ENV=development
PORT=4001

# Admin credentials — you set these. When set, seed creates only this admin (no demo data).
# Production: set these in .env.production; see DEPLOY.md § 3.4. Local dev: comment out for demo seed.
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=change_me_strong_admin_password
SEED_ADMIN_NAME=Admin
