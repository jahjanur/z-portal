generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int                @id @default(autoincrement())
  email          String             @unique
  password       String
  role           String
  name           String
  createdAt      DateTime           @default(now())
  company        String?
  logo           String?
  colorHex       String?
  address        String?
  postalAddress  String?
  phoneNumber    String?
  extraEmails    String?
  brandPattern   String?
  shortInfo      String?
  nickname       String?
  avatarEmoji    String?
  skills         String[]           @default([])
  profileStatus  String?            @default("INCOMPLETE")
  inviteToken    String?            @unique
  inviteExpires  DateTime?
  referredById   Int?
  referredBy     User?              @relation("ReferredClients", fields: [referredById], references: [id])
  referredClients User[]            @relation("ReferredClients")
  domains        Domain[]           @relation("ClientDomains")
  fileComments   FileComment[]
  invoices       Invoice[]          @relation("ClientInvoices")
  clientProjects Project[]          @relation("ClientProjects")
  clientTasks    Task[]             @relation("ClientTasks")
  taskAssignments TaskWorker[]      @relation("TaskWorkers")
  taskComments   TaskComment[]
  projects       TimesheetProject[] @relation("UserProjects")
  notifications  Notification[]
  sentInvites    Invite[]           @relation("InviteSender")
  notificationPreferences NotificationPreference[]
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  clientId    Int?
  status      String    @default("ACTIVE")
  serviceType String    @default("OTHER") // WEB_APP | WEBSITE | SMM | OTHER
  metadata    Json?     // service-type-specific fields (ad spend, features, pages, …)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  client      User?     @relation("ClientProjects", fields: [clientId], references: [id])
  tasks       Task[]    @relation("ProjectTasks")

  @@index([clientId])
  @@index([status])
}

model Domain {
  id                      Int       @id @default(autoincrement())
  clientId                Int
  domainName              String
  isPrimary               Boolean   @default(false)
  isActive                Boolean   @default(true)
  notes                   String?
  activationDate          DateTime?
  expirationDate          DateTime?
  lifespanYears           Int?
  hostingProvider         String?
  hostingPlan             String?
  hostingExpiry           DateTime?
  status                  String    @default("PENDING")
  activationEmailSentAt   DateTime?
  renewalReminderSentAt   DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @default(now()) @updatedAt
  client                  User      @relation("ClientDomains", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expirationDate])
}

model Task {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  status      String        @default("PENDING")
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  clientId    Int
  projectId   Int?
  client      User          @relation("ClientTasks", fields: [clientId], references: [id])
  project     Project?      @relation("ProjectTasks", fields: [projectId], references: [id])
  workers     TaskWorker[]
  comments    TaskComment[]
  files       TaskFile[]

  @@index([projectId])
}

model TaskWorker {
  id     Int  @id @default(autoincrement())
  taskId Int
  userId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User @relation("TaskWorkers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

enum FileReviewStatus {
  PENDING
  APPROVED
  NEEDS_REVISION
  REJECTED
}

model TaskFile {
  id             Int              @id @default(autoincrement())
  taskId         Int
  fileName       String
  fileUrl        String
  fileType       String
  caption        String?
  section        String?
  isCompleted    Boolean          @default(false)
  completedAt    DateTime?
  completedBy    Int?
  uploadedAt     DateTime         @default(now())
  uploadedBy     Int
  version        Int              @default(1)
  reviewStatus    FileReviewStatus @default(PENDING)
  reviewComment   String?
  visibleToClient Boolean          @default(true)
  comments        FileComment[]
  task           Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model FileComment {
  id              Int      @id @default(autoincrement())
  fileId          Int
  userId          Int
  content         String
  visibleToClient Boolean  @default(false)
  createdAt       DateTime @default(now())
  file            TaskFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])
}

model TaskComment {
  id              Int      @id @default(autoincrement())
  taskId          Int
  userId          Int
  content         String
  visibleToClient Boolean  @default(false)
  createdAt       DateTime @default(now())
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])
}

model Invoice {
  id            Int       @id @default(autoincrement())
  invoiceNumber String    @unique
  amount        Float
  dueDate       DateTime
  status        String    @default("PENDING")
  description   String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  fileUrl       String?
  paymentLink   String?
  clientId      Int
  client        User      @relation("ClientInvoices", fields: [clientId], references: [id])
  issueDate     DateTime?
  paymentTerms  String?
  notes         String?
  subtotal      Float?
  taxRate       Float?
  taxAmount     Float?
  lineItems     InvoiceLineItem[]
}

model InvoiceLineItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Float
  unitPrice   Float
  sortOrder   Int      @default(0)

  @@index([invoiceId])
}

model TimesheetProject {
  id          Int              @id @default(autoincrement())
  projectName String
  clientId    Int?
  description String?
  isPaid      Boolean          @default(false)
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  entries     TimesheetEntry[]
  client      User?            @relation("UserProjects", fields: [clientId], references: [id])

  @@index([clientId])
  @@index([isPaid])
}

model TimesheetEntry {
  id          Int              @id @default(autoincrement())
  projectId   Int
  date        DateTime
  hoursWorked Float
  hourlyRate  Float
  totalPay    Float
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  project     TimesheetProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([date])
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  link       String?
  sourceRole String?  // comment author role for TASK_COMMENT_ADDED (CLIENT | WORKER | ADMIN | ERASPHERE)
  taskId     Int?     // for TASK_COMMENT_ADDED: task this comment belongs to
  threadType String?  // "internal" | "client" for per-tab badges on task detail
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([userId, createdAt])
  @@index([userId, type, sourceRole])
  @@index([userId, taskId, threadType])
}

model Invite {
  id            Int       @id @default(autoincrement())
  email         String
  role          String
  tokenHash     String    @unique
  name          String
  company       String?
  domainName    String?
  domainExpiry  String?
  hostingPlan   String?
  hostingExpiry String?
  invitedById   Int
  invitedBy     User      @relation("InviteSender", fields: [invitedById], references: [id])
  used          Boolean   @default(false)
  cancelled     Boolean   @default(false)
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime

  @@index([tokenHash])
  @@index([email])
  @@index([expiresAt])
}

model NotificationPreference {
  id           Int     @id @default(autoincrement())
  userId       Int
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType    String
  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)

  @@unique([userId, eventType])
  @@index([userId])
}
