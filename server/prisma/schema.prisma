generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int                @id @default(autoincrement())
  email          String             @unique
  password       String
  role           String
  name           String
  createdAt      DateTime           @default(now())
  company        String?
  logo           String?
  colorHex       String?
  address        String?
  postalAddress  String?
  phoneNumber    String?
  extraEmails    String?
  brandPattern   String?
  shortInfo      String?
  nickname       String?
  avatarEmoji    String?
  skills         String[]           @default([])
  profileStatus  String?            @default("INCOMPLETE")
  inviteToken    String?            @unique
  inviteExpires  DateTime?
  resetToken     String?            @unique
  resetExpires   DateTime?
  referredById   Int?
  referredBy     User?              @relation("ReferredClients", fields: [referredById], references: [id])
  referredClients User[]            @relation("ReferredClients")
  companyOwnerId Int?
  companyOwner   User?              @relation("CompanyTeam", fields: [companyOwnerId], references: [id])
  teamMembers    User[]             @relation("CompanyTeam")
  domains        Domain[]           @relation("ClientDomains")
  servers        Server[]           @relation("ClientServers")
  fileComments   FileComment[]
  invoices       Invoice[]          @relation("ClientInvoices")
  clientProjects Project[]          @relation("ClientProjects")
  clientTasks    Task[]             @relation("ClientTasks")
  seoOrders      SeoOrder[]         @relation("ClientSeoOrders")
  taskAssignments TaskWorker[]      @relation("TaskWorkers")
  taskComments   TaskComment[]
  projects       TimesheetProject[] @relation("UserProjects")
  notifications  Notification[]
  sentInvites    Invite[]           @relation("InviteSender")
  notificationPreferences NotificationPreference[]
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  clientId    Int?
  status      String    @default("ACTIVE")
  serviceType String    @default("OTHER") // WEB_APP | WEBSITE | SMM | OTHER
  metadata    Json?     // service-type-specific fields (ad spend, features, pages, …)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  client      User?     @relation("ClientProjects", fields: [clientId], references: [id])
  tasks       Task[]    @relation("ProjectTasks")

  @@index([clientId])
  @@index([status])
}

model Domain {
  id                      Int       @id @default(autoincrement())
  clientId                Int
  domainName              String
  isPrimary               Boolean   @default(false)
  isActive                Boolean   @default(true)
  notes                   String?
  activationDate          DateTime?
  expirationDate          DateTime?
  lifespanYears           Int?
  hostingProvider         String?
  hostingPlan             String?
  hostingExpiry           DateTime?
  status                  String    @default("PENDING")
  activationEmailSentAt   DateTime?
  renewalReminderSentAt   DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @default(now()) @updatedAt
  client                  User      @relation("ClientDomains", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expirationDate])
}

model Server {
  id                      Int       @id @default(autoincrement())
  clientId                Int
  label                   String
  provider                String?
  ipAddress               String?
  plan                    String?
  location                String?
  notes                   String?
  activationDate          DateTime?
  expirationDate          DateTime?
  lifespanYears           Int?
  price                   Float?    // what we charge the client, per billingCycle
  providerCost            Float?    // what we pay the provider, per billingCycle
  currency                String    @default("EUR")
  billingCycle            String    @default("YEARLY") // MONTHLY | YEARLY
  status                  String    @default("PENDING")
  isActive                Boolean   @default(true)
  renewalReminderSentAt   DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @default(now()) @updatedAt
  client                  User      @relation("ClientServers", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expirationDate])
}

model Task {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  status      String        @default("PENDING")
  dueDate     DateTime?
  pinnedAt    DateTime?     // when set, the task is pinned to the top of its board column
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  clientId    Int
  projectId   Int?
  client      User          @relation("ClientTasks", fields: [clientId], references: [id])
  project     Project?      @relation("ProjectTasks", fields: [projectId], references: [id])
  workers     TaskWorker[]
  comments    TaskComment[]
  files       TaskFile[]
  milestones  Milestone[]
  seoOrder    SeoOrder?

  @@index([projectId])
}

// ---------------- SEO backlink catalog (packages we resell) ----------------

// A sellable SEO package: the client-facing offer AND the provider spec we buy
// (both representations kept, per the catalog doc). backlinkProfile is
// structured [{da, qty}]; contentPieces is [{qty, label}].
model SeoPackage {
  id                Int        @id @default(autoincrement())
  name              String     // Core / Growth / Authority / Apex
  positioning       String?
  active            Boolean    @default(true)
  sortOrder         Int        @default(0)
  // sell side
  price             Float
  currency          String     @default("EUR")
  features          String[]   @default([])   // client-facing bullets (cumulative up tiers)
  highlights        String[]   @default([])   // öne çıkan özellikler
  // buy side (provider spec)
  providerName      String?    // upstream provider (future: multiple providers)
  providerPackage   String?    // Altın / Vip / Elite Master / Elite Leader
  providerCost      Float?     // ₺
  providerListPrice Float?     // ₺
  // volumes & timeline
  backlinks         Int
  packageItems      Int
  maxKeywords       Int
  deliveryDaysMin   Int
  deliveryDaysMax   Int
  processingHours   Int        @default(24)
  guaranteeMonths   Int        @default(12)
  contentPieces     Json?      // [{qty, label}]
  backlinkProfile   Json?      // [{da, qty}]
  createdAt         DateTime   @default(now())
  orders            SeoOrder[]
}

// An activated package for a client. Linked 1:1 to a Task so chat/workers/
// files/notifications come for free; the task detail shows an SEO panel
// (intake + status) instead of To-dos.
model SeoOrder {
  id          Int        @id @default(autoincrement())
  packageId   Int
  package     SeoPackage @relation(fields: [packageId], references: [id])
  clientId    Int
  client      User       @relation("ClientSeoOrders", fields: [clientId], references: [id])
  taskId      Int?       @unique
  task        Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  invoiceId   Int?
  // AWAITING_INFO → INFO_RECEIVED → SENT_TO_PROVIDER → IN_PROGRESS → DELIVERED (or CANCELLED)
  status      String     @default("AWAITING_INFO")
  // intake (what we need from the client to start)
  websiteUrl  String?
  sector      String?
  language    String?    @default("English")
  chooseLinks Boolean    @default(false)
  keywords    Json?      // [{keyword, targetUrl}]
  note        String?
  createdAt   DateTime   @default(now())
  infoAt      DateTime?
  completedAt DateTime?

  @@index([clientId])
}

model Milestone {
  id          Int       @id @default(autoincrement())
  taskId      Int
  title       String
  description String?
  imageUrl    String?
  imageUrls   String[]  @default([])
  pushedToGithub Boolean @default(false)
  deployed    Boolean   @default(false)
  isDone      Boolean   @default(false)
  doneAt      DateTime?
  doneBy      Int?
  priority    String    @default("MEDIUM")   // HIGH | MEDIUM | LOW
  createdById Int
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  commentLinks CommentMilestoneLink[]

  @@index([taskId])
}

// Many-to-many link between a chat message and a to-do (milestone). Lets a
// message be attached to one or more to-dos; the to-do shows its linked
// messages and each side can jump to the other.
model CommentMilestoneLink {
  id          Int         @id @default(autoincrement())
  commentId   Int
  milestoneId Int
  createdAt   DateTime    @default(now())
  comment     TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  milestone   Milestone   @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([commentId, milestoneId])
  @@index([commentId])
  @@index([milestoneId])
}

model TaskWorker {
  id     Int  @id @default(autoincrement())
  taskId Int
  userId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User @relation("TaskWorkers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

enum FileReviewStatus {
  PENDING
  APPROVED
  NEEDS_REVISION
  REJECTED
}

model TaskFile {
  id             Int              @id @default(autoincrement())
  taskId         Int
  fileName       String
  fileUrl        String
  fileType       String
  caption        String?
  section        String?
  isCompleted    Boolean          @default(false)
  completedAt    DateTime?
  completedBy    Int?
  uploadedAt     DateTime         @default(now())
  uploadedBy     Int
  version        Int              @default(1)
  reviewStatus    FileReviewStatus @default(PENDING)
  reviewComment   String?
  visibleToClient Boolean          @default(true)
  comments        FileComment[]
  task           Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model FileComment {
  id              Int      @id @default(autoincrement())
  fileId          Int
  userId          Int
  content         String
  visibleToClient Boolean  @default(false)
  createdAt       DateTime @default(now())
  file            TaskFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])
}

model TaskComment {
  id              Int      @id @default(autoincrement())
  taskId          Int
  userId          Int
  content         String
  visibleToClient Boolean  @default(false)
  createdAt       DateTime @default(now())
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])
  milestoneLinks  CommentMilestoneLink[]
}

model Invoice {
  id            Int       @id @default(autoincrement())
  invoiceNumber String    @unique
  amount        Float
  currency      String    @default("USD")
  dueDate       DateTime
  status        String    @default("PENDING")
  description   String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  fileUrl       String?
  paymentLink   String?
  clientId      Int
  client        User      @relation("ClientInvoices", fields: [clientId], references: [id])
  issueDate     DateTime?
  paymentTerms  String?
  notes         String?
  subtotal      Float?
  taxRate       Float?
  taxAmount     Float?
  lineItems     InvoiceLineItem[]
  payments      Payment[]
}

model Payment {
  id         Int      @id @default(autoincrement())
  invoiceId  Int
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount     Float
  paidAt     DateTime @default(now())
  note       String?
  receiptUrl String?
  createdAt  DateTime @default(now())

  @@index([invoiceId])
}

model InvoiceLineItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Float
  unitPrice   Float
  sortOrder   Int      @default(0)

  @@index([invoiceId])
}

// Singleton (id=1) app-wide settings. Currency conversion: rates are expressed
// as how many USD one unit of the currency is worth (USD is the pivot).
model AppSetting {
  id              Int      @id @default(1)
  displayCurrency String   @default("USD")
  usdPerEur       Float    @default(1.08)
  usdPerCad       Float    @default(0.73)
  updatedAt       DateTime @default(now()) @updatedAt
}

model TimesheetProject {
  id          Int              @id @default(autoincrement())
  projectName String
  clientId    Int?
  description String?
  isPaid      Boolean          @default(false)
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  entries     TimesheetEntry[]
  client      User?            @relation("UserProjects", fields: [clientId], references: [id])

  @@index([clientId])
  @@index([isPaid])
}

model TimesheetEntry {
  id          Int              @id @default(autoincrement())
  projectId   Int
  date        DateTime
  hoursWorked Float
  hourlyRate  Float
  totalPay    Float
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  project     TimesheetProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([date])
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  link       String?
  sourceRole String?  // comment author role for TASK_COMMENT_ADDED (CLIENT | WORKER | ADMIN | ERASPHERE)
  taskId     Int?     // for TASK_COMMENT_ADDED: task this comment belongs to
  threadType String?  // "internal" | "client" for per-tab badges on task detail
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([userId, createdAt])
  @@index([userId, type, sourceRole])
  @@index([userId, taskId, threadType])
}

model Invite {
  id            Int       @id @default(autoincrement())
  email         String
  role          String
  tokenHash     String    @unique
  name          String
  company       String?
  companyOwnerId Int?
  domainName    String?
  domainExpiry  String?
  hostingPlan   String?
  hostingExpiry String?
  invitedById   Int
  invitedBy     User      @relation("InviteSender", fields: [invitedById], references: [id])
  used          Boolean   @default(false)
  cancelled     Boolean   @default(false)
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime

  @@index([tokenHash])
  @@index([email])
  @@index([expiresAt])
}

model NotificationPreference {
  id           Int     @id @default(autoincrement())
  userId       Int
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType    String
  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)

  @@unique([userId, eventType])
  @@index([userId])
}
